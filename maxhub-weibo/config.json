{
  "name": "maxhub-weibo",
  "displayName": "微博数据采集与分析",
  "displayNameEn": "Weibo Data Collection & Analysis",
  "version": "1.0.8",
  "description": "微博热搜、话题、用户与博文数据采集",
  "descriptionEn": "Weibo hot search, topic, user and post data collection",
  "author": "MaxHub Team",
  "license": "MIT",
  "homepage": "https://www.aconfig.cn",
  "repository": "https://github.com/XieWxx/maxhub-api-skills",
  "platform": "weibo",
  "emoji": "🔥",
  "trigger": "微博|weibo|热搜|超话|话题|微博搜索",
  "categories": [
    "social-media",
    "data-collection",
    "trending"
  ],
  "tools": [
    "http"
  ],
  "requires": {
    "env": [
      "MAXHUB_API_KEY"
    ],
    "primaryEnv": "MAXHUB_API_KEY"
  },
  "config": {
    "default_page_size": {
      "type": "number",
      "default": 20,
      "description": "默认每页返回条数"
    },
    "max_chain_depth": {
      "type": "number",
      "default": 3,
      "description": "链式调用最大深度"
    },
    "cost_alert_threshold": {
      "type": "number",
      "default": 20,
      "description": "连续调用超过此数值时提醒费用"
    }
  },
  "apiBase": {
    "url": "https://www.aconfig.cn",
    "authHeader": "x-api-key",
    "authEnvVar": "MAXHUB_API_KEY",
    "prefix": "/api/v1/weibo"
  },
  "rateLimit": {
    "maxPages": 5,
    "maxResults": 50,
    "maxBatchSize": 10,
    "requestsPerMinute": 60
  },
  "privacyNote": "User query parameters are sent to the configured API provider (aconfig.cn). Do not submit sensitive private information."
}
