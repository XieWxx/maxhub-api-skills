{
  "userProfile": {
    "fields": ["nickname", "uniqueId", "uid", "signature", "ipLocation", "followerCount", "followingCount", "totalFavorited", "awemeCount", "isVerified"],
    "highlight": ["followerCount", "totalFavorited"],
    "order": ["nickname", "uniqueId", "uid", "signature", "ipLocation", "followerCount", "followingCount", "totalFavorited", "awemeCount"]
  },
  "videoInfo": {
    "fields": ["title", "author.nickname", "statistics.playCount", "statistics.diggCount", "statistics.commentCount", "statistics.shareCount", "statistics.collectCount", "duration", "createTime", "tags"],
    "highlight": ["statistics.playCount"],
    "order": ["title", "author", "playCount", "diggCount", "commentCount", "shareCount", "collectCount", "duration", "createTime", "tags"]
  },
  "hotSearch": {
    "fields": ["rank", "title", "hotValue", "tag"],
    "highlight": ["rank", "hotValue"],
    "maxDisplay": 20,
    "order": ["rank", "title", "hotValue", "tag"]
  },
  "comments": {
    "fields": ["author", "text", "diggCount", "ipLocation", "createTime", "replyCount"],
    "highlight": ["diggCount"],
    "maxDisplay": 20,
    "order": ["author", "text", "diggCount", "ipLocation", "createTime", "replyCount"]
  },
  "liveData": {
    "fields": ["title", "owner.nickname", "status", "userCount", "likeCount"],
    "highlight": ["userCount", "status"],
    "order": ["title", "owner", "status", "userCount", "likeCount"]
  }
}
